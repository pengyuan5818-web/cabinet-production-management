# 橱柜工厂管理系统 - 环境变量配置
# 复制此文件为 .env 并修改配置

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cabinet_factory
DB_USER=postgres
DB_PASSWORD=postgres

# JWT配置
JWT_SECRET=cabinet-factory-secret-key-2026
JWT_EXPIRES_IN=7d

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# 日志
LOG_DIR=./logs

# 考勤机配置（海康威视SDK）
HIKVISION_SDK_HOST=192.168.1.64
HIKVISION_SDK_PORT=8000

# 扫码枪/扬声器配置
SERIAL_PORT=COM3
SERIAL_BAUD=115200

# 标签打印机
PRINTER_NAME=ZDesigner ZD420C
